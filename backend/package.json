{
  "name": "genai",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "nodemon",
    "dev:watch": "nodemon --watch src --ext ts,js,json --exec ts-node --transpile-only src/index.ts",
    "dev:debug": "nodemon --inspect --watch src --ext ts,js,json --exec ts-node --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "npm run build && npm start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:basic": "jest --testPathPatterns=basic.test.ts",
    "test:utils": "jest --testPathPatterns=utils.test.ts",
    "test:services": "jest --testPathPatterns=services.test.ts",
    "test:controllers": "jest --testPathPatterns=controllers.test.ts",
    "test:all": "jest --testPathPatterns=\"(basic|utils|services|controllers).test.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.6.2",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.902.0",
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/lib-dynamodb": "^3.902.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@pinecone-database/pinecone": "^4.1.0",
    "@types/multer": "^2.0.0",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.35",
    "mammoth": "^1.11.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "openai": "^6.33.0",
    "path": "^0.12.7",
    "pdf2json": "^4.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  }
}
